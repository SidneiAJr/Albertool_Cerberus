{
  "name": "albertool-cerberus",
  "displayName": "Albertool Cerberus",
  "description": "🐺 Monitor de servidor e rotas para projetos Node.js",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cerberus-sidebar",
          "title": "🐺 Cerberus",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "cerberus-sidebar": [
         {
            "id": "cerberus-routes",
            "name": "🐺 Cerberus — Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "cerberus.refresh",
        "title": "🔄 Atualizar",
        "icon": "$(refresh)"
      },
      {
        "command": "cerberus.setPort",
        "title": "🔧 Mudar Porta"
      },
      {
        "command": "cerberus.copyRoute",
        "title": "📋 Copiar Rota"
      },
      {
        "command": "cerberus.scanPorts",
        "title": "🔍 Escanear Portas"
      }
    ],
    "menus": {
          "view/title": [
        {
            "command": "cerberus.refresh",
            "when": "view == cerberus-routes",  
            "group": "navigation"
        }
    ]
    },
    "keybindings": [
      {
        "command": "cerberus.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SidneiAJr/Albertool_Cerberus"
  },
  "publisher": "SidAlbertaodasmassa",
  "license": "MIT"
}