{
  "name": "albertool-cerberus",
  "displayName": "Albertool Cerberus",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
        "activitybar": [
            {
                "id": "cerberus-sidebar",
                "title": "Cerberus",
                "icon": "$(server)"
            }
        ]
    },
    "views": {
        "cerberus-sidebar": [
            {
                "id": "cerberus-server",
                "name": "🐺 Server Monitor"
            },
            {
                "id": "cerberus-routes",
                "name": "📡 Rotas"
            }
        ]
    },
    "commands": [
    {
        "command": "cerberus.refresh",
        "title": "Cerberus: Atualizar",
        "icon": "$(refresh)"
    },
    {
        "command": "cerberus.setPort",
        "title": "Cerberus: Mudar Porta"
    },
    {
        "command": "cerberus.copyRoute",
        "title": "Cerberus: Copiar Rota"
    }
],
    "menus": {
        "view/title": [
            {
                "command": "cerberus.refresh",
                "when": "view == cerberus-routes",
                "group": "navigation"
            }
        ]
    }
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.18.1"
  }
}
